{"version":3,"file":"span.js","names":[],"sources":["../../../../otel/src/span.ts"],"sourcesContent":["import {\n  type Attributes,\n  type Span,\n  type Tracer,\n  context,\n} from '@opentelemetry/api';\n\nexport function startSpan<T>(\n  tracer: Tracer,\n  name: string,\n  cb: (span: Omit<Span, 'end'>) => T,\n): T {\n  return tracer.startActiveSpan(name, span => {\n    try {\n      return cb(span);\n    } finally {\n      span.end();\n    }\n  });\n}\n\nexport function startAsyncSpan<T>(\n  tracer: Tracer,\n  name: string,\n  cb: (span: Omit<Span, 'end'>) => Promise<T>,\n): Promise<T> {\n  return tracer.startActiveSpan(name, async span => {\n    try {\n      return await cb(span);\n    } finally {\n      span.end();\n    }\n  });\n}\n\nexport function manualSpan(\n  tracer: Tracer,\n  name: string,\n  durationMs: number,\n  attributes?: Attributes,\n): void {\n  const startTime = Date.now() - durationMs;\n  const span = tracer.startSpan(name, {startTime}, context.active());\n  if (attributes) {\n    span.setAttributes(attributes);\n  }\n  span.end(startTime + durationMs);\n}\n"],"mappings":";;AAOA,SAAgB,UACd,QACA,MACA,IACG;AACH,QAAO,OAAO,gBAAgB,OAAM,SAAQ;AAC1C,MAAI;AACF,UAAO,GAAG,KAAK;YACP;AACR,QAAK,KAAK;;GAEZ;;AAGJ,SAAgB,eACd,QACA,MACA,IACY;AACZ,QAAO,OAAO,gBAAgB,MAAM,OAAM,SAAQ;AAChD,MAAI;AACF,UAAO,MAAM,GAAG,KAAK;YACb;AACR,QAAK,KAAK;;GAEZ;;AAGJ,SAAgB,WACd,QACA,MACA,YACA,YACM;CACN,MAAM,YAAY,KAAK,KAAK,GAAG;CAC/B,MAAM,OAAO,OAAO,UAAU,MAAM,EAAC,WAAU,EAAE,QAAQ,QAAQ,CAAC;AAClE,KAAI,WACF,MAAK,cAAc,WAAW;AAEhC,MAAK,IAAI,YAAY,WAAW"}