{
  "name": "zero-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/zero-app/src",
  "tags": ["type:app", "scope:zero-app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist", "{projectRoot}/.output", "{projectRoot}/.nitro"],
      "options": {
        "cwd": "apps/zero-app",
        "command": "vite build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/zero-app",
        "command": "vite dev --port 3000"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/zero-app",
        "command": "vite preview"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/zero-app",
        "command": "vitest run --passWithNoTests"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/zero-app/src/**/*.ts", "apps/zero-app/src/**/*.tsx"]
      }
    }
  }
}
