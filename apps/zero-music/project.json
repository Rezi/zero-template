{
  "name": "zero-music",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/zero-music/src",
  "tags": ["type:app", "scope:music"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/.output",
        "{projectRoot}/.nitro"
      ],
      "options": {
        "cwd": "apps/zero-music",
        "command": "vite build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/zero-music",
        "command": "vite dev --port 3000"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/zero-music",
        "command": "vite preview"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/zero-music",
        "command": "vitest run --passWithNoTests"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "apps/zero-music/src/**/*.ts",
          "apps/zero-music/src/**/*.tsx"
        ]
      }
    }
  }
}
