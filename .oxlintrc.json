{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "react", "jsx-a11y", "import", "unicorn", "oxc", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    // Automatic JSX runtime (tsconfig `jsx: react-jsx`) — `React` need not be in scope.
    "react/react-in-jsx-scope": "off",
    // Sequential awaits are intentional throughout the interactive dev wizard.
    "no-await-in-loop": "off",
    // CSS (and other asset) side-effect imports cannot be assigned — allow them.
    "import/no-unassigned-import": ["warn", { "allow": ["**/*.css"] }]
  },
  "ignorePatterns": [
    "**/node_modules",
    "**/dist",
    "**/.nitro",
    "**/.tanstack",
    "**/.output",
    "**/.vinxi",
    "**/playwright-report",
    "**/test-results",
    "**/routeTree.gen.ts"
  ],
  "overrides": [
    {
      "files": ["**/*.{test,spec}.{ts,tsx}", "**/*.e2e.ts"],
      "env": { "vitest": true }
    },
    {
      // Generated/vendored shadcn-ui primitives. Their source is owned upstream and
      // is overwritten by `shadcn add`, so the project's a11y/style rules are relaxed
      // here rather than hand-editing files that regeneration would revert.
      "files": ["libs/ui-library/src/components/ui/**", "libs/ui-library/src/hooks/**"],
      "rules": {
        "jsx-a11y/prefer-tag-over-role": "off",
        "jsx-a11y/no-noninteractive-element-interactions": "off",
        "jsx-a11y/label-has-associated-control": "off",
        "jsx-a11y/click-events-have-key-events": "off",
        "jsx-a11y/anchor-has-content": "off",
        "no-shadow": "off",
        "no-underscore-dangle": "off",
        "react/no-unstable-nested-components": "off",
        "react/no-array-index-key": "off",
        "react/jsx-no-constructed-context-values": "off"
      }
    }
  ]
}
