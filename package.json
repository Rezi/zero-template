{
  "name": "zero-app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "nx serve zero-app",
    "build": "nx build zero-app",
    "preview": "nx preview zero-app",
    "test": "nx run-many --target=test",
    "lint": "nx run-many --target=lint",
    "e2e": "nx e2e zero-app-e2e",
    "graph": "nx graph",
    "zero-cache": "ZERO_QUERY_URL='http://localhost:3000/api/query' ZERO_MUTATE_URL='http://localhost:3000/api/mutate' npx zero-cache-dev",
    "db:generate": "drizzle-kit generate --config libs/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config libs/db/drizzle.config.ts",
    "db:push": "drizzle-kit push --config libs/db/drizzle.config.ts",
    "generate-zero-schema": "drizzle-zero generate -c libs/db/drizzle-zero.config.ts -f -o libs/zero/src/lib/schema.ts"
  },
  "dependencies": {
    "@rocicorp/zero": "^1.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.6.17",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "pg": "^8.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "^22.7.5",
    "@nx/eslint-plugin": "^22.7.5",
    "@nx/playwright": "^22.7.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-zero": "^0.18.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "jsonc-eslint-parser": "^3.1.0",
    "nx": "^22.7.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@rocicorp/zero-sqlite3",
      "esbuild",
      "lightningcss"
    ]
  }
}
